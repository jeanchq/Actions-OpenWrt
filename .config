# ======================================
# 核心平台适配（MT7986A 专属）
# ======================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7986=y
CONFIG_TARGET_mediatek_mt7986_DEVICE_generic=y
CONFIG_ARCH_64BIT=y
CONFIG_NR_CPUS=4  # 适配 MT7986A 核心数

# ======================================
# 1. 2G 内存优化（SWAP + 大页内存 + 内存压缩）
# ======================================
# 内核级 SWAP 支持
CONFIG_KERNEL_SWAP=y
CONFIG_KERNEL_ZSWAP=y
CONFIG_KERNEL_HUGETLB_PAGE=y
CONFIG_KERNEL_HUGETLBFS=y
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE=y
# 用户态 SWAP 工具（必须）
CONFIG_PACKAGE_swap-utils=y
CONFIG_PACKAGE_zram-swap=y  # 内存压缩交换，提升 2G 内存利用率
CONFIG_PACKAGE_libucl=y     # zram 依赖库

# ======================================
# 2. 128G EMMC 适配（EXT4/NTFS 完整支持）
# ======================================
# EXT4 驱动 + 工具
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_parted=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_lsblk=y
# NTFS 驱动（双驱动保障，适配 128G 大容量）
CONFIG_PACKAGE_kmod-fs-ntfs3=y  # 原生 NTFS3 驱动（高性能）
CONFIG_PACKAGE_ntfs-3g=y        # 兼容型 NTFS 驱动
CONFIG_PACKAGE_ntfs-3g-utils=y
# EMMC 底层驱动（MT7986A 专属）
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_kmod-mmc-core=y
CONFIG_PACKAGE_kmod-sdhci=y
CONFIG_PACKAGE_kmod-sdhci-pltfm=y
CONFIG_PACKAGE_kmod-mtk-mmc=y   # MTK 专属 EMMC 驱动
# 分区优化（128G EMMC 分配 100G 根分区）
CONFIG_TARGET_ROOTFS_PARTSIZE=102400
CONFIG_TARGET_ROOTFS_EXT4=y

# ======================================
# 3. USB3.0 全驱动（MT7986A 原生 USB3.0 支持）
# ======================================
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y                # USB3.0 核心驱动
CONFIG_PACKAGE_kmod-usb-xhci=y           # XHCI 主控制器（MT7986A 标配）
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
CONFIG_PACKAGE_kmod-usb-ehci=y
CONFIG_PACKAGE_usb-modeswitch=y          # USB 模式切换（兼容网卡/U盘）
CONFIG_PACKAGE_usbutils=y                # USB 工具（lsusb 调试）
CONFIG_PACKAGE_kmod-usb-storage=y        # USB 存储驱动
CONFIG_PACKAGE_kmod-usb-storage-extras=y # 扩展 USB 存储支持

# ======================================
# 4. 网卡驱动（MT7531AE + RTL8221B 完整适配）
# ======================================
# MT7531AE 驱动（MT7986A 配套交换机）
CONFIG_PACKAGE_kmod-mt7530=y
CONFIG_PACKAGE_kmod-mt7531=y
CONFIG_PACKAGE_mtk-eeprom=y
CONFIG_PACKAGE_kmod-net-dsa=y
CONFIG_PACKAGE_kmod-net-dsa-mt7530=y
CONFIG_PACKAGE_kmod-mediatek-ge-phy=y    # MTK 千兆 PHY 驱动
# RTL8221B 驱动（光口/电口适配）
CONFIG_PACKAGE_kmod-r8169=y
CONFIG_PACKAGE_kmod-realtek=y
CONFIG_PACKAGE_kmod-phy-realtek=y
CONFIG_PACKAGE_kmod-rtl8221=y
CONFIG_PACKAGE_kmod-rtl8211e=y
# 网络调试工具
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_iproute2=y
CONFIG_PACKAGE_ss=y

# ======================================
# 5. MT7986A 专属优化（可选）
# ======================================
CONFIG_PACKAGE_kmod-mt7986-firmware=y    # MT7986A 固件
CONFIG_PACKAGE_kmod-mediatek-wifi=y      # MT7986A 无线驱动（如需无线功能）
CONFIG_PACKAGE_kmod-mtk-hsdma=y          # MTK 高速 DMA 驱动
CONFIG_PACKAGE_kmod-mediatek-thermal=y   # 温度监控
CONFIG_PACKAGE_hwmon=y                   # 硬件监控

# ======================================
# 6. 基础功能（易用性）
# ======================================
CONFIG_PACKAGE_luci=y                    # LuCI 网页管理
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y    # 中文界面
CONFIG_PACKAGE_luci-theme-argon=y        # 美观主题
CONFIG_PACKAGE_opkg=y                    # 包管理
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ttyd=y                    # 网页终端（调试用）
