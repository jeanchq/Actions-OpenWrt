# S20PLUS 基础配置
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_MEDIATEK_FILOGIC_MT7986A=y
CONFIG_TARGET_mediatek_filogic_DEVICE_mediatek_mt7986a-s20plus=y
CONFIG_TARGET_BOARD="filogic"
CONFIG_TARGET_SUBTARGET="filogic"
CONFIG_TARGET_PROFILE="DEFAULT"
CONFIG_TARGET_ARCH_PACKAGES="aarch64_cortex-a53"

# 128G EMMC 配置
CONFIG_TARGET_KERNEL_PARTSIZE=512
CONFIG_TARGET_ROOTFS_PARTSIZE=102400
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_kmod-sdhci=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y

# USB3.0 配置
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-xhci=y
CONFIG_PACKAGE_kmod-usb-storage=y

# S20PLUS 网口拓扑
CONFIG_PACKAGE_kmod-mt7530=y
CONFIG_PACKAGE_kmod-mt7531=y
CONFIG_PACKAGE_kmod-switch-mt7530=y
CONFIG_PACKAGE_swconfig=y
CONFIG_PACKAGE_kmod-libphy=y
CONFIG_PACKAGE_kmod-rtl8221=y
CONFIG_PACKAGE_kmod-mdio-gpio=y
CONFIG_PACKAGE_kmod-of-mdio=y
CONFIG_PACKAGE_kmod-r8169=y
CONFIG_PACKAGE_ethtool=y

# 基础功能
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iproute2=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_bridge=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-proto-pppoe=y

# 关闭无用功能
CONFIG_PACKAGE_luci-app-vlmcsd=n
CONFIG_PACKAGE_luci-app-ddns=n
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-passwall=y
