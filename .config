CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_mt7986=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_HAS_SUBTARGETS=y

# ==============================================
# 只保留 CLX S20P（删除所有其他设备）
# ==============================================
CONFIG_TARGET_DEVICE_mediatek_filogic_DEVICE_mediatek_mt7986a-clx-s20p=y
CONFIG_TARGET_DEVICE_PACKAGES_mediatek_filogic_DEVICE_mediatek_mt7986a-clx-s20p=""

# ==============================================
# 关闭 WiFi（纯有线、超低延迟）
# ==============================================
CONFIG_WIFI_SUPPORT=n
# CONFIG_MTK_CHIP_MT7986 is not set
# CONFIG_MTK_CONNINFRA_APSOC is not set
# CONFIG_MTK_CONNINFRA_APSOC_MT7986 is not set
# CONFIG_MTK_MT_WIFI is not set
# CONFIG_PACKAGE_kmod-mt_wifi is not set
# CONFIG_PACKAGE_iwinfo is not set
# CONFIG_PACKAGE_iw is not set
# CONFIG_PACKAGE_wireless-regdb is not set
# CONFIG_PACKAGE_wireless-tools is not set
# CONFIG_PACKAGE_mtwifi-cfg is not set
# CONFIG_PACKAGE_luci-app-mtwifi-cfg is not set
# CONFIG_PACKAGE_luci-i18n-mtwifi-cfg-zh-cn is not set

# ==============================================
# 硬件加速 HWNAT 全开（低延迟核心）
# ==============================================
CONFIG_PACKAGE_kmod-mediatek_hnat=y
CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_kmod-ipt-offload=y
CONFIG_PACKAGE_luci-app-turboacc-mtk=y
CONFIG_PACKAGE_luci-i18n-turboacc-mtk-zh-cn=y
CONFIG_PACKAGE_TURBOACC_INCLUDE_NO_FASTPATH=y
CONFIG_MTK_WHNAT_SUPPORT=y
CONFIG_MTK_FAST_NAT_SUPPORT=y

# ==============================================
# 网络性能优化
# ==============================================
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_switch=y
CONFIG_PACKAGE_mii_mgr=y
CONFIG_PACKAGE_regs=y
CONFIG_PACKAGE_mtk-smp=y
CONFIG_PACKAGE_mtkhqos_util=y

# ==============================================
# 内核低延迟配置
# ==============================================
CONFIG_KERNEL_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_KERNEL_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_KERNEL_HZ=1000
CONFIG_KERNEL_PREEMPT_VOLUNTARY=y
CONFIG_KERNEL_HIGH_RES_TIMERS=y

# ==============================================
# 你原有插件 100% 保留
# ==============================================
