CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_mediatek_mt7986a-clx-s20p=y
CONFIG_DEVEL=y
CONFIG_NEED_TOOLCHAIN_BUILD=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y

# 关闭 WiFi（纯有线，超低延迟）
CONFIG_WIFI_SUPPORT=n
# CONFIG_MT7986_WMAC is not set
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set

# HWNAT 硬件加速（内核6.6专用）
CONFIG_PACKAGE_kmod-mtk-hnat=y
CONFIG_PACKAGE_kmod-hw-nat=y
CONFIG_MTK_HNAT=y
CONFIG_NET_FLOW_OFFLOAD=y

# BBR + 低延迟队列
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_kmod-sched-fq-codel=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_htop=y

# 网络驱动（双2.5G + 5口正常）
CONFIG_PACKAGE_kmod-mt7986-eth=y
CONFIG_PACKAGE_kmod-mt7531-phy=y
CONFIG_PACKAGE_kmod-swconfig=y

# USB3.0
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-fs-ext4=y

# 性能模式（不省电、不跳频、最低延迟）
CONFIG_KERNEL_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_KERNEL_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_KERNEL_HZ=1000
CONFIG_KERNEL_PREEMPT_VOLUNTARY=y
CONFIG_KERNEL_HIGH_RES_TIMERS=y

# 关闭无用功能
CONFIG_DEBUG=n
CONFIG_SAFE_DOWNLOAD=n
CONFIG_PACKAGE_snmpd is not set
CONFIG_PACKAGE_qos-scripts is not set
CONFIG_PACKAGE_wol is not set
CONFIG_PACKAGE_ddns is not set
